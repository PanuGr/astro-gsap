---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<div class="stained-glass h-100 p-4 rounded" data-reveal>
  <h3 class="card-title text-primary d-flex align-items-center gap-2 mb-3">
    <slot name="icon" />
    {title}
  </h3>
  <p class="m-0">
    <slot />
  </p>
</div>