---
import "../styles/index.scss";
import { Font } from "astro:assets";
import { ArrowUp } from "@lucide/astro";
---

<html lang="en">
  <head>
    <link
      rel="preload"
      as="image"
      href="/banner-2700.avif"
      type="image/avif"
      media="(min-width: 1200px)"
    />
    <link
      rel="preload"
      as="image"
      href="/banner-1700.avif"
      type="image/avif"
    />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicon/apple-touch-icon.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicon/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicon/favicon-16x16.png"
    />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <title>Kirikla Monastery</title>
    <meta
      name="description"
      content="The only Orthodox men's monastery in Estonia. A living place of prayer, work, and monastic community, rooted in the tradition of Mount Athos."
    />
    <Font cssVariable="--headings" />
  </head>
  <body>
    <a href="#main-content" class="visually-hidden-focusable"
      >Skip to main content</a
    >
    <a
      href="#"
      id="back-to-top"
      class="btn btn-primary back-to-top"
      aria-label="Back to top"
    >
      <ArrowUp size={20} />
    </a>
    <div
      id="custom-cursor"
      class="custom-cursor d-none d-sm-block"
      aria-hidden="true"
    >
    </div>
    <slot />
    <script>
      const buttonUp = document.querySelector("#back-to-top");

      window.onscroll = function (e) {
        if (window.scrollY > 600) {
          buttonUp.style.visibility = "visible";
        } else {
          buttonUp.style.visibility = "hidden";
        }
      };
      buttonUp.onclick = () => window.scrollTo(0, 0);

      import "../lib/reveal.js";
      import "../lib/parallax.js";
      import "../lib/tilt3d.js";
      import "../lib/candle.js";
      import "../lib/cursor.js";
    </script>
  </body>
</html>
