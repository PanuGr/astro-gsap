---
import "../styles/index.scss";
import { Font } from "astro:assets";
---

<html lang="en">
  <head>
    <link rel="preconnect" href="https://images.unsplash.com" />
    <link
      rel="preload"
      as="image"
      href="https://images.unsplash.com/photo-1602376531381-e2bc41a27f74?fm=avif&q=10&w=1600"
    />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Kirikla Monastery</title>
    <meta
      name="description"
      content="The only Orthodox men's monastery in Estonia. A living place of prayer, work, and monastic community, rooted in the tradition of Mount Athos."
    />
    <Font cssVariable="--headings" />
  </head>
  <body>
    <a href="#main-content" class="visually-hidden-focusable"
      >Skip to main content</a
    >

    <slot />
  </body>
</html>
